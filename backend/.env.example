# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Vision + text model. Anthropic Claude on Bedrock.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# Set to "1" to bypass Bedrock and return deterministic mock AI data
# (useful before AWS credentials are configured)
MOCK_AI=1
