# Copy to .env.production on the server and fill in. NEVER commit this file.

# --- Public domain (Caddy HTTPS) ---
DOMAIN=fithub.shravanmeena.com

# --- Cloud SQL (PostgreSQL) ---
# Connection name from the instance Overview, e.g. shravanmeena:us-central1:fithub-db
CLOUD_SQL_CONNECTION=shravanmeena:us-central1:fithub-db
PGUSER=postgres
PGPASSWORD=Postgres@123
PGDATABASE=fithub
# (PGHOST/PGPORT are set by docker-compose to reach the proxy)

# --- Cloud Storage (uploads) ---
GCS_BUCKET=fithub-uploads-shravan

# --- Server ---
PORT=4000
JWT_SECRET=replace-with-a-long-random-string

# --- AWS Bedrock (AI) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=arn:aws:bedrock:ap-south-1:900932786656:inference-profile/global.anthropic.claude-opus-4-6-v1
MOCK_AI=0

# --- Platform super-admin (your company login) ---
SUPERADMIN_EMAIL=shravanmeena47@gmail.com
SUPERADMIN_PASSWORD=Shravan@123

# --- Push notifications (Firebase Cloud Messaging) ---
# Paste the Firebase service-account JSON on ONE line (Project Settings ->
# Service accounts -> Generate new private key). Leave empty to disable push.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}
