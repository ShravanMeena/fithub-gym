# Copy to .env.production on the server and fill in. NEVER commit this file.

# Public domain for Caddy HTTPS (point its A record at the VM's external IP).
DOMAIN=api.yourgym.com

# Server
PORT=4000
JWT_SECRET=replace-with-a-long-random-string

# AWS Bedrock (AI). Use a least-privilege key (bedrock:InvokeModel only).
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=arn:aws:bedrock:ap-south-1:900932786656:inference-profile/global.anthropic.claude-opus-4-6-v1
MOCK_AI=0

# Platform super-admin (the company login)
SUPERADMIN_EMAIL=you@yourcompany.com
SUPERADMIN_PASSWORD=replace-with-a-strong-password
